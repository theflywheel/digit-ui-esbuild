{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DIGIT UI Theme Config",
  "type": "object",
  "required": ["version", "colors"],
  "additionalProperties": true,
  "properties": {
    "version": { "const": "1" },
    "name": { "type": "string" },
    "code": { "type": "string" },
    "colors": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "primary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "light":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#F18F5E" },
            "main":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#c84c0e" },
            "dark":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#C8602B" },
            "accent":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#F47738" },
            "selected-bg":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#FBEEE8" }
          }
        },
        "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#22394D" },
        "text": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#0B0C0C" },
            "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#505A5F" },
            "heading":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#363636" },
            "muted":     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#787878" }
          }
        },
        "link": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "normal": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#1D70B8" },
            "hover":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#003078" }
          }
        },
        "border":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#D6D5D4" },
        "input-border": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#464646" },
        "error":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#D4351C" },
        "error-dark":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#B91900" },
        "success":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#00703C" },
        "info-dark":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#0057BD" },
        "warning-dark": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#9E5F00" },
        "grey": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dark":     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#9E9E9E" },
            "disabled": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#C5C5C5" },
            "mid":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#EEEEEE" },
            "lighter":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#F0F0F0" },
            "light":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#FAFAFA" },
            "bg":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#E3E3E3" }
          }
        },
        "digitv2": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "text-color-disabled": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#B1B4B6" },
            "header-sidenav":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#0B4B66" },
            "primary-bg":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#FEEFE7" },
            "alert-error-bg":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#EFC7C1" },
            "alert-success-bg":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#BAD6C9" },
            "alert-info":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#3498DB" },
            "alert-info-bg":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#C7E0F1" },
            "chart-1":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#048BD0" },
            "chart-2":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#FBC02D" },
            "chart-3":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#8E29BF" },
            "chart-4":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#EA8A3B" },
            "chart-5":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#0BABDE" }
          }
        },
        "shell-tint":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#E8F3EE" },
        "cta-tint":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#FEC93133" },
        "disabled-content": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#BDCAC3" },
        "tertiary-border":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#EDEDED" },
        "muted-bg":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#F3F4F6" },
        "tag-status": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "warning-bg":     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#FEF3C7" },
            "warning-border": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#FAE29F" },
            "warning-label":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#92400E" },
            "info-bg":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#F3E8FF" },
            "info-border":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#E4CCFF" },
            "info-label":     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#6B21A8" },
            "success-bg":     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#DCFCE7" },
            "success-border": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#A9FFC7" },
            "success-label":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$", "default": "#166534" }
          }
        }
      }
    }
  }
}
