{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DIGIT UI Theme Config",
  "type": "object",
  "required": ["version", "colors"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string", "enum": ["1", "2", "3"] },
    "name": { "type": "string" },
    "code": { "type": "string" },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brand":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "brand-on":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "surface-header": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "surface-page":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "text-heading":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "text-primary":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "text-secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "text-disabled":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "info":           { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "warning":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "selected-bg":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "chart-palette": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
        },
        "primary-1":                  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "primary-2":                  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "primary-1-bg":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "primary-2-bg":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "page-bg":                    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "page-secondary-bg":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-primary-bg-default":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-primary-bg-hover":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-primary-bg-pressed":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-primary-text":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-primary-border":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-primary-disabled-bg": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-primary-disabled-text": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-secondary-bg-default": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-secondary-bg-hover":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-secondary-bg-pressed":{ "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-secondary-text":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-secondary-border":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "button-tertiary-text":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "input-bg":                   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "input-border-default":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "input-border-focus":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "input-border-error":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "input-placeholder":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "input-text":                 { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "input-label":                { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "input-helper":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "header-bg":                  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "header-text":                { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "header-icon":                { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "sidebar-bg":                 { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "sidebar-text-active":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "sidebar-text-default":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "sidebar-hover-text":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "sidebar-hover-bg":           { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "sidebar-icon-active":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "sidebar-selected-bg":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "sidebar-selected-text":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "card-border":                { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "card-divider":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "card-success":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "card-error":                 { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-success-text":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-success-bg":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-success-border":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-error-text":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-error-bg":            { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-error-border":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-warning-text":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-warning-bg":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-warning-border":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-info-text":           { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-info-bg":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "status-info-border":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-header-bg":            { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-header-text":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-row-bg":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-alt-row":              { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-row-text":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-border":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-hover":                { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-selected":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-hover-text":           { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "table-selected-text":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "loader":                     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "progress":                   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "tooltip-bg":                 { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "tooltip-text":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "chart-1":                    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "chart-2":                    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "chart-3":                    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "chart-4":                    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "chart-5":                    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "primary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "light":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#F18F5E" },
            "main":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#c84c0e" },
            "dark":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#C8602B" },
            "accent":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#F47738" },
            "selected-bg":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#FBEEE8" }
          }
        },
        "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#22394D" },
        "text": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#0B0C0C" },
            "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#505A5F" },
            "heading":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#363636" },
            "muted":     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#787878" }
          }
        },
        "link": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "normal": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#1D70B8" },
            "hover":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#003078" }
          }
        },
        "border":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#D6D5D4" },
        "input-border": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#464646" },
        "error":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#D4351C" },
        "error-dark":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#B91900" },
        "success":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#00703C" },
        "info-dark":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#0057BD" },
        "warning-dark": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#9E5F00" },
        "grey": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dark":     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#9E9E9E" },
            "disabled": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#C5C5C5" },
            "mid":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#EEEEEE" },
            "lighter":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#F0F0F0" },
            "light":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#FAFAFA" },
            "bg":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#E3E3E3" }
          }
        },
        "digitv2": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "text-color-disabled": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#B1B4B6" },
            "header-sidenav":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#0B4B66" },
            "primary-bg":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#FEEFE7" },
            "alert-error-bg":      { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#EFC7C1" },
            "alert-success-bg":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#BAD6C9" },
            "alert-info":          { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#3498DB" },
            "alert-info-bg":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#C7E0F1" },
            "chart-1":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#048BD0" },
            "chart-2":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#FBC02D" },
            "chart-3":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#8E29BF" },
            "chart-4":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#EA8A3B" },
            "chart-5":             { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#0BABDE" }
          }
        }
      }
    }
  }
}
